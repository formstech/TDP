<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Arteaga Accessories</title>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>

:root{
  --bg:#050816;
  --card:rgba(17,24,39,.78);
  --line:rgba(255,255,255,.08);

  --primary:#00E5FF;
  --primary2:#00B8D4;

  --text:#ffffff;
  --muted:#94A3B8;

  --success:#25D366;

  --radius:28px;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:'Montserrat',sans-serif;
  min-height:100vh;

  background:
  radial-gradient(circle at top left,#0ea5e950,transparent 35%),
  radial-gradient(circle at bottom right,#7c3aed50,transparent 35%),
  var(--bg);

  display:flex;
  align-items:center;
  justify-content:center;

  padding:20px;
  overflow-x:hidden;
}

/* CONTENEDOR */

.container{
  width:100%;
  max-width:520px;
}

/* TARJETA */

.card{

  position:relative;

  background:var(--card);

  backdrop-filter:blur(18px);

  border:1px solid var(--line);

  border-radius:var(--radius);

  padding:38px 28px;

  text-align:center;

  overflow:hidden;

  box-shadow:
  0 20px 60px rgba(0,0,0,.45);

}

/* BRILLO */

.card::before{

  content:"";

  position:absolute;

  width:240px;
  height:240px;

  background:rgba(0,229,255,.12);

  border-radius:50%;

  top:-120px;
  right:-120px;

  filter:blur(10px);

}

/* FOTO */

.photo{

  width:140px;
  height:140px;

  border-radius:50%;

  margin:auto;

  border:3px solid rgba(255,255,255,.15);

  background-image:url('TU_FOTO.jpg');

  background-size:cover;
  background-position:center;

  box-shadow:
  0 0 30px rgba(0,229,255,.45);

}

/* BADGE */

.badge{

  display:inline-block;

  margin-top:18px;

  padding:8px 16px;

  border-radius:999px;

  background:rgba(0,229,255,.12);

  color:var(--primary);

  font-size:.8rem;

  font-weight:700;

  letter-spacing:.5px;

  border:1px solid rgba(0,229,255,.25);

}

/* TITULO */

h1{

  margin-top:18px;

  color:var(--text);

  font-size:2rem;

  font-weight:800;

}

/* SUB */

.role{

  margin-top:10px;

  color:var(--muted);

  font-size:.98rem;

  line-height:1.6;

}

/* PRODUCTOS */

.products{

  display:flex;

  flex-wrap:wrap;

  justify-content:center;

  gap:10px;

  margin-top:25px;

}

.product{

  padding:10px 14px;

  border-radius:14px;

  background:rgba(255,255,255,.05);

  border:1px solid rgba(255,255,255,.06);

  color:#E2E8F0;

  font-size:.85rem;

  font-weight:600;

}

/* BOTONES */

.buttons{

  margin-top:30px;

  display:flex;

  flex-direction:column;

  gap:15px;

}

.btn{

  text-decoration:none;

  padding:16px;

  border-radius:18px;

  font-weight:700;

  transition:.3s ease;

  display:flex;

  align-items:center;

  justify-content:center;

  gap:10px;

}

/* WHATSAPP */

.btn-whatsapp{

  background:linear-gradient(135deg,#25D366,#1ebe5d);

  color:white;

  box-shadow:
  0 15px 35px rgba(37,211,102,.35);

}

.btn-whatsapp:hover{

  transform:translateY(-3px) scale(1.02);

}

/* SECUNDARIOS */

.btn-secondary{

  background:rgba(255,255,255,.05);

  border:1px solid rgba(255,255,255,.08);

  color:white;

}

.btn-secondary:hover{

  background:rgba(255,255,255,.09);

  transform:translateY(-2px);

}

/* REDES */

.socials{

  display:flex;

  justify-content:center;

  gap:14px;

  margin-top:28px;

}

.social{

  width:46px;
  height:46px;

  border-radius:14px;

  display:flex;
  align-items:center;
  justify-content:center;

  background:rgba(255,255,255,.05);

  color:white;

  text-decoration:none;

  font-size:1.2rem;

  transition:.3s;

}

.social:hover{

  transform:translateY(-4px);

  background:rgba(0,229,255,.15);

}

/* FOOTER */

.footer{

  margin-top:30px;

  color:#64748B;

  font-size:.8rem;

}

/* RESPONSIVE */

@media(max-width:480px){

  .card{
    padding:34px 22px;
  }

  h1{
    font-size:1.7rem;
  }

  .photo{
    width:120px;
    height:120px;
  }

}

</style>
</head>

<body>

<div class="container">

  <div class="card">

    <div class="photo"></div>

    <div class="badge">
      ACCESORIOS PREMIUM
    </div>

    <h1>Arteaga Accessories</h1>

    <div class="role">
      Cases, micas, audífonos, cargadores y accesorios originales
      para darle más estilo y protección a tu celular.
    </div>

    <div class="products">

      <div class="product">📱 Micas</div>

      <div class="product">🎧 Audífonos</div>

      <div class="product">🔋 Cargadores</div>

      <div class="product">📲 Cases</div>

      <div class="product">⌚ Smartwatch</div>

    </div>

    <div class="buttons">

      <a href="https://wa.me/521XXXXXXXXXX"
      target="_blank"
      class="btn btn-whatsapp">

      📲 Pedir por WhatsApp

      </a>

      <a href="https://wa.me/c/521XXXXXXXXXX"
      target="_blank"
      class="btn btn-secondary">

      🛒 Ver Catálogo

      </a>

      <a href="tel:+52XXXXXXXXXX"
      class="btn btn-secondary">

      📞 Llamar

      </a>

      <a href="#"
      class="btn btn-secondary">

      📍 Ver Ubicación

      </a>

    </div>

    <div class="socials">

      <a href="#" class="social">📘</a>

      <a href="#" class="social">📸</a>

      <a href="#" class="social">🎵</a>

    </div>

    <div class="footer">
      Tecnología · Estilo · Protección
    </div>

  </div>

</div>

</body>
</html>
